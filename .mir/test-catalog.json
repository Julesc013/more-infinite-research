{
  "schema": 1,
  "tests": [
    {
      "id": "docs.check",
      "kind": "static",
      "command": "./scripts/Invoke-MIRValidation.ps1 -DocsOnly",
      "requires_factorio": false,
      "inputs": [
        "docs/**",
        "README.md",
        "CONTRIBUTING.md",
        "todo.md",
        "AGENTS.md",
        ".mir/docs.yml",
        "scripts/Invoke-MIRValidation.ps1",
        "scripts/Test-MIRGovernance.ps1"
      ]
    },
    {
      "id": "tooling.self-test",
      "kind": "static",
      "command": "./scripts/Test-MIRAssurance.ps1",
      "requires_factorio": false,
      "inputs": [
        "scripts/Invoke-MIRAssurance.ps1",
        "scripts/MIRAssurance/**",
        "scripts/Test-MIRAssurance.ps1",
        ".mir/assurance.json",
        ".mir/test-catalog.json",
        ".mir/test-impact.yml",
        "target-profile"
      ]
    },
    {
      "id": "static.architecture",
      "kind": "static",
      "command": "./scripts/Invoke-MIRValidation.ps1 -ArchitectureOnly",
      "requires_factorio": false,
      "inputs": [
        "scripts/Invoke-MIRValidation.ps1",
        "scripts/Test-MIRArchitecture.ps1",
        "scripts/Test-MIRGovernance.ps1",
        "scripts/Test-MIRSettingsVisibility.ps1",
        "scripts/Get-MIRLegacyInventory.ps1",
        "scripts/validation/**",
        ".mir/modules.yml",
        ".mir/targets.json",
        ".mir/settings.yml",
        "prototypes/**"
      ]
    },
    {
      "id": "static.compiler",
      "kind": "static",
      "command": "./scripts/Test-MIRCompiler.ps1",
      "requires_factorio": false,
      "inputs": [
        "scripts/Test-MIRCompiler.ps1",
        "scripts/Test-MIRCompilerSchemaDrift.ps1",
        "scripts/Test-MIRCompilerContractCoverage.ps1",
        ".mir/compiler-contract-coverage.yml",
        "prototypes/mir/**",
        "fixtures/compat-matrix/expected-scenarios.json",
        "fixtures/assert-compiler-contracts/**",
        "docs/reference/compiler-authority-table.md",
        "docs/reference/schemas/**"
      ]
    },
    {
      "id": "static.settings",
      "kind": "static",
      "command": "./scripts/Test-MIRSettings.ps1",
      "requires_factorio": false,
      "inputs": [
        "scripts/Test-MIRSettings.ps1",
        "settings",
        "locale/en/**",
        ".mir/targets.json"
      ]
    },
    {
      "id": "static.locales",
      "kind": "static",
      "command": "./scripts/Test-MIRLocales.ps1 -AllowMissingSupportedLanguages",
      "requires_factorio": false,
      "inputs": [
        "scripts/Test-MIRLocales.ps1",
        "locale/**",
        "settings",
        ".mir/targets.json"
      ]
    },
    {
      "id": "static.balance",
      "kind": "static",
      "command": "./scripts/mir.ps1 assurance balance",
      "requires_factorio": false,
      "inputs": [
        "scripts/mir.ps1",
        "scripts/Invoke-MIRAssurance.ps1",
        "scripts/MIRAssurance/**",
        "scripts/Test-MIRNativeOwnerCostModels.ps1",
        ".mir/streams.yml",
        ".mir/settings.yml",
        ".mir/native-owner-cost-models.json",
        "prototypes/mir/planner/costs.lua",
        "prototypes/mir/domain/native_owner/**",
        "prototypes/mir/planner/native_owner_binding.lua",
        "prototypes/mir/streams/generated_stream_manifest.json"
      ]
    },
    {
      "id": "static.package",
      "kind": "static",
      "command": "./scripts/Test-MIRDeterministicPackage.ps1",
      "requires_factorio": false,
      "inputs": [
        "scripts/Test-MIRDeterministicPackage.ps1",
        "scripts/Build-MIRPackage.ps1",
        "scripts/validation/PackageIdentity.ps1",
        "info.json",
        "package-source"
      ]
    },
    {
      "id": "static.full",
      "kind": "static",
      "command": "./scripts/Invoke-MIRValidation.ps1 -StaticOnly",
      "requires_factorio": false,
      "inputs": [
        "repository"
      ]
    },
    {
      "id": "runtime.affected",
      "kind": "runtime",
      "command": "./scripts/Invoke-MIRValidation.ps1 -FactorioBin <factorio> -CandidateZip <candidate> -ChangedSince <baseline> -Tier impacted",
      "requires_factorio": true,
      "inputs": [
        "candidate",
        "package-source",
        "factorio",
        "selected-scenarios",
        "scripts/Invoke-MIRValidation.ps1",
        "scripts/validation/**",
        "fixtures",
        "settings"
      ]
    },
    {
      "id": "runtime.exact-zip",
      "kind": "runtime",
      "command": "./scripts/Invoke-MIRValidation.ps1 -FactorioBin <factorio> -CandidateZip <candidate> -Tier smoke",
      "requires_factorio": true,
      "inputs": [
        "candidate",
        "package-source",
        "factorio",
        "exact-dist-scenarios",
        "scripts/Invoke-MIRValidation.ps1",
        "scripts/validation/**",
        "fixtures",
        "settings"
      ]
    },
    {
      "id": "runtime.full",
      "kind": "runtime",
      "command": "./scripts/Invoke-MIRValidation.ps1 -FactorioBin <factorio> -CandidateZip <candidate> -Tier full",
      "requires_factorio": true,
      "inputs": [
        "candidate",
        "package-source",
        "factorio",
        "required-scenarios",
        "scripts/Invoke-MIRValidation.ps1",
        "scripts/validation/**",
        "fixtures",
        "settings"
      ]
    },
    {
      "id": "runtime.upgrade",
      "kind": "runtime",
      "command": "./scripts/Test-MIRUpgrade.ps1 -FactorioBin <factorio> -FromZip <prior-release> -ToZip <candidate> -FromVersion 2.3.5 -ToVersion 2.4.0 -FixtureName assert-upgrade-2-3-5-to-2-4-0 -OutputPath artifacts/assurance/2.4.0-upgrade-proof.json",
      "requires_factorio": true,
      "inputs": [
        "candidate",
        "package-source",
        "prior-release",
        "factorio",
        "upgrade-fixture",
        "scripts/Test-MIRUpgrade.ps1",
        "scripts/validation/**",
        "settings"
      ]
    },
    {
      "id": "runtime.ecosystem",
      "kind": "runtime",
      "command": "./scripts/mir.ps1 release gate --profile release-targeted-2.0 --factorio <factorio> --no-git-pull",
      "requires_factorio": true,
      "inputs": [
        "candidate",
        "package-source",
        "factorio",
        "mod-lock",
        "ecosystem-profile",
        "scripts/mir.ps1",
        "scripts/Invoke-MIRReleaseTargetedGate.ps1",
        "scripts/Invoke-MIRCompatAudit.ps1",
        "scripts/MIRCompatAudit/**",
        "scripts/MIRCli/**",
        "fixtures"
      ]
    },
    {
      "id": "seal.verify",
      "kind": "promotion",
      "command": "./scripts/mir.ps1 assurance check-seal --seal <seal> --json",
      "requires_factorio": false,
      "inputs": [
        "candidate-seal",
        "candidate",
        "package-source",
        "target-profile",
        "test-catalog",
        "harness",
        "evidence"
      ]
    }
  ]
}
