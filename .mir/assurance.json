{
  "schema": 1,
  "default_target": "2.1",
  "verification": {
    "tests": "validation/tests.yml",
    "domains": "validation/domains.yml",
    "profiles": "validation/profiles",
    "trust": "validation/trust.json",
    "plan": "out/verification-plan.json",
    "evidence": "artifacts/assurance/evidence",
    "aggregate_gate": "MIR / verification-gate"
  },
  "profiles": {
    "edit": ["static.architecture", "static.compiler"],
    "fast": ["tooling.self-test", "static.architecture", "static.compiler", "static.settings", "static.balance", "static.museum", "static.release-history", "static.package"],
    "auto": [],
    "locale": ["static.locales", "runtime.exact-zip"],
    "balance": ["static.balance", "runtime.affected"],
    "refactor-equivalence": ["static.compiler", "static.package", "runtime.exact-zip"],
    "hotfix": ["static.full", "runtime.affected", "runtime.exact-zip"],
    "targeted": ["static.full", "runtime.affected", "runtime.exact-zip"],
    "full": ["docs.check", "tooling.self-test", "static.architecture", "static.compiler", "static.settings", "static.locales", "static.balance", "static.museum", "static.release-history", "static.package", "static.full", "performance.static", "runtime.exact-zip", "runtime.full", "runtime.upgrade", "runtime.ecosystem", "release.approved-delta", "runtime.performance-regression", "manual.release-review"],
    "backport": ["docs.check", "tooling.self-test", "static.architecture", "static.compiler", "static.settings", "static.locales", "static.balance", "static.museum", "static.release-history", "static.package", "static.full", "performance.static", "runtime.exact-zip", "runtime.full", "runtime.upgrade", "runtime.ecosystem", "runtime.performance-regression", "manual.release-review"],
    "promotion-check": ["seal.verify"]
  },
  "classes": [
    {
      "id": "runtime-or-migration",
      "patterns": ["^control\\.lua$", "^migrations/", "^prototypes/mir/runtime/", "^prototypes/mir/stage/control\\.lua$"],
      "tests": ["static.full", "runtime.full", "runtime.upgrade"]
    },
    {
      "id": "settings",
      "patterns": ["^settings", "^prototypes/mir/settings/", "^\\.mir/settings\\.yml$"],
      "tests": ["static.settings", "static.locales", "static.compiler", "runtime.affected", "runtime.upgrade", "runtime.exact-zip"]
    },
    {
      "id": "compiler-data-stage",
      "patterns": ["^data", "^prototypes/", "^\\.mir/(modules|streams|compatibility|capabilities|compiler-contract-coverage)\\.yml$"],
      "tests": ["static.compiler", "static.architecture", "static.package", "runtime.affected", "runtime.exact-zip"]
    },
    {
      "id": "balance",
      "patterns": ["^prototypes/mir/planner/costs\\.lua$", "^prototypes/streams/", "^prototypes/mir/domain/native_owner/", "^prototypes/mir/planner/native_owner_binding\\.lua$", "^prototypes/mir/emit/transactions/productivity_family_adoption\\.lua$", "^\\.mir/native-owner-cost-models\\.json$", "^\\.mir/performance-budgets\\.json$"],
      "tests": ["static.balance", "static.compiler", "runtime.affected", "runtime.exact-zip"]
    },
    {
      "id": "locale",
      "patterns": ["^locale/", "^\\.mir/locales/", "^scripts/localization/", "^scripts/(Test|Update)-MIRLocales\\.ps1$"],
      "tests": ["static.locales", "static.package", "runtime.exact-zip"]
    },
    {
      "id": "metadata-dependencies",
      "patterns": ["^info\\.json$"],
      "tests": ["static.package", "runtime.full", "runtime.upgrade", "runtime.exact-zip"]
    },
    {
      "id": "packaged-non-runtime",
      "patterns": ["^(README\\.md|changelog\\.txt|thumbnail\\.png|LICENSE)$"],
      "tests": ["static.package", "runtime.exact-zip"]
    },
    {
      "id": "assurance-tooling",
      "patterns": ["^scripts/(?:Invoke-MIRAssurance|Test-MIR(?:Assurance|ReleaseAuthority))\\.ps1$", "^scripts/MIRAssurance/", "^validation/tests\\.yml$", "^\\.mir/(assurance|test-impact)\\.(json|yml)$"],
      "tests": ["tooling.self-test", "static.full"]
    },
    {
      "id": "test-harness",
      "patterns": ["^scripts/(?!MIRAssurance/)(?!(?:Invoke-MIRAssurance|Test-MIR(?:Assurance|ReleaseAuthority))\\.ps1$)", "^fixtures/", "^validation/(?!tests\\.yml$)", "^verification/", "^tools/mir_verify/", "^\\.mir/(fixtures|test-catalog|targets|performance)", "^\\.github/workflows/", "^\\.gitignore$"],
      "tests": ["tooling.self-test", "static.full", "runtime.affected"]
    },
    {
      "id": "release-governance",
      "patterns": ["^\\.mir/(branches|distributions|releases)\\.(json|yml)$", "^\\.mir/(portable-return|release-wave)\\.yml$"],
      "tests": ["docs.check", "tooling.self-test", "static.release-history", "static.full", "static.package"]
    },
    {
      "id": "museum-tooling",
      "patterns": ["^\\.mir/(canonical-lower-features|museum-targets)\\.json$", "^scripts/(Build-MIRMuseumTarget|New-MIRMuseum|Test-MIRMuseum)", "^scripts/Museum/"],
      "tests": ["static.museum"]
    },
    {
      "id": "repository-docs",
      "patterns": ["^docs/", "^\\.mir/(branches|convergence|docs)\\.yml$", "^CONTRIBUTING\\.md$", "^todo\\.md$", "^AGENTS\\.md$"],
      "tests": ["docs.check"]
    },
    {
      "id": "release-evidence",
      "patterns": ["^\\.mir/(evidence|target-lines)/", "^approved-delta/", "^dist/"],
      "tests": ["tooling.self-test", "static.release-history", "static.full", "static.package"]
    }
  ],
  "unknown_policy": {
    "tests": ["static.full", "runtime.full", "runtime.upgrade", "runtime.ecosystem"],
    "reason": "Unclassified inputs conservatively invalidate the full target gate."
  },
  "fingerprints": {
    "package_source": true,
    "package_content": true,
    "test_catalog": true,
    "validation_harness": true,
    "trust_policy": true,
    "target_profile": true,
    "settings": true,
    "factorio_binary": true,
    "fixture_inputs": true
  }
}
