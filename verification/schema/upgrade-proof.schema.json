{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://more-infinite-research.invalid/verification/upgrade-proof.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "generated_at",
    "package_source_commit",
    "evidence_commit",
    "factorio_binary_version",
    "factorio_binary_sha256",
    "from",
    "to",
    "assertions",
    "companion_fixtures",
    "create_log",
    "create_log_sha256",
    "load_log",
    "load_log_sha256"
  ],
  "properties": {
    "schema": {"const": 2},
    "status": {"const": "passed"},
    "generated_at": {"type": "string", "format": "date-time"},
    "package_source_commit": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "evidence_commit": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "factorio_binary_version": {"type": "string", "minLength": 1},
    "factorio_binary_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "from": {"$ref": "#/$defs/archive"},
    "to": {"$ref": "#/$defs/archive"},
    "assertions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "companion_fixtures": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "create_log": {"type": "string", "minLength": 1},
    "create_log_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "load_log": {"type": "string", "minLength": 1},
    "load_log_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}
  },
  "$defs": {
    "archive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "path", "sha256"],
      "properties": {
        "version": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}
      }
    }
  }
}
