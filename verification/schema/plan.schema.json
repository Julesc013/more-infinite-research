{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://more-infinite-research.invalid/verification/plan.schema.json",
  "title": "MIR canonical verification plan",
  "type": "object",
  "required": [
    "schema",
    "policy_id",
    "generated_at",
    "target",
    "profile",
    "source_commit",
    "source_tree",
    "candidate_descriptor",
    "candidate_descriptor_sha256",
    "expected_test_ids",
    "required_test_set_sha256",
    "policy_sha256",
    "plan_material_sha256",
    "tests"
  ],
  "properties": {
    "schema": { "const": 4 },
    "policy_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "target": { "type": "string", "minLength": 1 },
    "profile": { "type": "string", "minLength": 1 },
    "baseline": { "type": "string" },
    "candidate": { "type": "string", "minLength": 1 },
    "classification": {},
    "impact_selection": {},
    "requires_factorio": { "type": "boolean" },
    "reuse_enabled": { "type": "boolean" },
    "rerun_tests": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "source_commit": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "source_tree": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "candidate_descriptor": { "type": "object" },
    "candidate_descriptor_sha256": { "$ref": "#/$defs/sha256" },
    "package_source_sha256": { "$ref": "#/$defs/sha256" },
    "test_catalog_sha256": { "$ref": "#/$defs/sha256" },
    "catalog_sha256": { "$ref": "#/$defs/sha256" },
    "validation_harness_sha256": { "$ref": "#/$defs/sha256" },
    "verification_profile_sha256": { "$ref": "#/$defs/sha256" },
    "domain_policy_sha256": { "$ref": "#/$defs/sha256" },
    "trust_policy_sha256": { "$ref": "#/$defs/sha256" },
    "policy_sha256": { "$ref": "#/$defs/sha256" },
    "expected_test_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "required_test_set_sha256": { "$ref": "#/$defs/sha256" },
    "plan_material_sha256": { "$ref": "#/$defs/sha256" },
    "producer": { "type": "object" },
    "domain_manifest": { "type": "object" },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "layer", "fingerprint", "disposition", "force_fresh"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "layer": { "enum": ["F0", "F1", "F2", "F3", "F4"] },
          "fingerprint": { "type": "object" },
          "disposition": { "enum": ["REUSE", "WAIT", "RUN", "INVALID"] },
          "force_fresh": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "work": { "type": "array" },
    "counts": { "type": "object" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
  },
  "additionalProperties": false
}
