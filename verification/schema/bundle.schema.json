{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://more-infinite-research.invalid/verification/bundle.schema.json",
  "title": "MIR aggregate evidence bundle",
  "type": "object",
  "required": [
    "schema",
    "policy_id",
    "status",
    "target",
    "plan_sha256",
    "plan_material_sha256",
    "required_test_set_sha256",
    "candidate_descriptor_sha256",
    "checks",
    "evidence",
    "capsule_set",
    "capsule_set_sha256",
    "bundle_sha256",
    "completed_at"
  ],
  "properties": {
    "schema": { "const": 2 },
    "policy_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed"] },
    "target": { "type": "string", "minLength": 1 },
    "plan_generated_at": { "type": "string", "format": "date-time" },
    "plan_sha256": { "$ref": "#/$defs/sha256" },
    "plan_material_sha256": { "$ref": "#/$defs/sha256" },
    "required_test_set_sha256": { "$ref": "#/$defs/sha256" },
    "candidate_descriptor": { "type": "object" },
    "candidate_descriptor_sha256": { "$ref": "#/$defs/sha256" },
    "candidate": { "type": "string" },
    "domain_manifest": {},
    "checks": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "evidence": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "capsule_set": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "capsule_set_sha256": { "$ref": "#/$defs/sha256" },
    "completed_at": { "type": "string", "format": "date-time" },
    "bundle_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
  },
  "additionalProperties": false
}
