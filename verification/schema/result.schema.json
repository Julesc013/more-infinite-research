{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://more-infinite-research.invalid/verification/result.schema.json",
  "title": "MIR structured test result",
  "type": "object",
  "required": ["schema", "test_id", "status", "exit_code", "assertions", "artifacts", "started_at", "completed_at"],
  "properties": {
    "schema": { "const": "mir-test-result-v1" },
    "test_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed"] },
    "exit_code": { "type": "integer" },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed"] },
          "evidence": {}
        },
        "additionalProperties": false
      }
    },
    "artifacts": { "type": "array", "items": { "type": "object" } },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "message": { "type": "string" }
  },
  "additionalProperties": false
}
