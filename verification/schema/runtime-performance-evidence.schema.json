{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://more-infinite-research.invalid/verification/runtime-performance-evidence.schema.json",
  "title": "MIR paired runtime performance evidence",
  "type": "object",
  "required": [
    "schema",
    "kind",
    "status",
    "candidate",
    "baseline",
    "factorio",
    "comparability",
    "run_policy",
    "run_order",
    "lanes",
    "artifact_volume"
  ],
  "properties": {
    "schema": { "const": 3 },
    "kind": { "const": "mir-runtime-performance-regression" },
    "status": { "const": "passed" },
    "candidate": { "$ref": "#/$defs/candidate" },
    "baseline": { "$ref": "#/$defs/package" },
    "factorio": { "$ref": "#/$defs/factorio" },
    "comparability": { "$ref": "#/$defs/comparability" },
    "run_policy": { "$ref": "#/$defs/runPolicy" },
    "run_order": {
      "type": "array",
      "minItems": 10,
      "items": { "enum": ["baseline", "candidate"] }
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lane" }
    },
    "artifact_volume": { "$ref": "#/$defs/artifactVolume" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "package": {
      "type": "object",
      "required": ["version", "archive_sha256", "package_content_sha256"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "archive_sha256": { "$ref": "#/$defs/sha256" },
        "package_content_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "candidate": {
      "type": "object",
      "required": ["version", "archive_sha256", "package_content_sha256", "source_commit"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "archive_sha256": { "$ref": "#/$defs/sha256" },
        "package_content_sha256": { "$ref": "#/$defs/sha256" },
        "source_commit": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" }
      },
      "additionalProperties": false
    },
    "factorio": {
      "type": "object",
      "required": ["version", "binary_sha256"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "binary_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "comparability": {
      "type": "object",
      "required": ["machine_sha256", "official_mods_sha256", "third_party_closure_sha256", "settings_sha256", "scenarios_sha256", "harness_sha256"],
      "properties": {
        "machine_sha256": { "$ref": "#/$defs/sha256" },
        "official_mods_sha256": { "$ref": "#/$defs/sha256" },
        "third_party_closure_sha256": { "$ref": "#/$defs/sha256" },
        "settings_sha256": { "$ref": "#/$defs/sha256" },
        "scenarios_sha256": { "$ref": "#/$defs/sha256" },
        "harness_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "runPolicy": {
      "type": "object",
      "required": ["warmup_runs", "minimum_measured_runs_per_package", "order"],
      "properties": {
        "warmup_runs": { "type": "integer", "minimum": 1 },
        "minimum_measured_runs_per_package": { "type": "integer", "minimum": 5 },
        "order": { "const": "paired-balanced" }
      },
      "additionalProperties": false
    },
    "statistics": {
      "type": "object",
      "required": ["runs_seconds", "median_seconds", "p90_seconds", "minimum_seconds", "maximum_seconds"],
      "properties": {
        "runs_seconds": { "type": "array", "minItems": 5, "items": { "type": "number", "minimum": 0 } },
        "median_seconds": { "type": "number", "minimum": 0 },
        "p90_seconds": { "type": "number", "minimum": 0 },
        "minimum_seconds": { "type": "number", "minimum": 0 },
        "maximum_seconds": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "lane": {
      "type": "object",
      "required": ["id", "baseline", "candidate", "absolute_delta_seconds", "percentage_delta", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "baseline": { "$ref": "#/$defs/statistics" },
        "candidate": { "$ref": "#/$defs/statistics" },
        "absolute_delta_seconds": { "type": "number" },
        "percentage_delta": { "type": ["number", "null"] },
        "status": { "const": "passed" }
      },
      "additionalProperties": false
    },
    "artifactVolume": {
      "type": "object",
      "required": ["telemetry_schema", "aggregation", "measurements"],
      "properties": {
        "telemetry_schema": { "const": 1 },
        "aggregation": { "const": "maximum-observed" },
        "measurements": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/artifactVolumeMeasurement" }
        }
      },
      "additionalProperties": false
    },
    "artifactVolumeMeasurement": {
      "type": "object",
      "required": ["surface", "measured_runs", "telemetry_fingerprints", "counters"],
      "properties": {
        "surface": { "enum": ["diagnostics-off", "diagnostics-on"] },
        "measured_runs": { "type": "integer", "minimum": 5 },
        "telemetry_fingerprints": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/sha256" }
        },
        "counters": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
