{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://more-infinite-research.invalid/verification/seal.schema.json",
  "title": "MIR release-candidate seal",
  "type": "object",
  "required": [
    "schema",
    "state",
    "release_status",
    "mir_version",
    "target",
    "source_commit",
    "source_tree",
    "candidate",
    "candidate_sha256",
    "candidate_content_sha256",
    "candidate_descriptor_sha256",
    "plan_material_sha256",
    "required_test_set_sha256",
    "evidence_bundle_sha256",
    "capsule_set_sha256",
    "performance_evidence",
    "performance_evidence_sha256",
    "performance_status",
    "manual_review_attestation",
    "manual_review_attestation_sha256",
    "manual_review_status",
    "verifier_release_sha256",
    "producer_attestation",
    "sealed_at",
    "seal_sha256"
  ],
  "properties": {
    "schema": { "const": 4 },
    "state": { "const": "SEALED-RC" },
    "release_status": { "const": "NOT RELEASED" },
    "version": { "type": "string" },
    "mir_version": { "type": "string" },
    "factorio_target": { "type": "string" },
    "target": { "type": "string" },
    "canonical_dev_anchor": { "type": "string" },
    "branch": { "type": "string" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "source_tree": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "source_clean": { "type": "boolean" },
    "candidate": { "type": "string", "minLength": 1 },
    "candidate_sha256": { "$ref": "#/$defs/sha256" },
    "candidate_content_sha256": { "$ref": "#/$defs/sha256" },
    "candidate_descriptor_sha256": { "$ref": "#/$defs/sha256" },
    "candidate_domain_manifest_sha256": { "$ref": "#/$defs/sha256" },
    "package_source_sha256": { "$ref": "#/$defs/sha256" },
    "target_profile_sha256": { "$ref": "#/$defs/sha256" },
    "verification_profile_sha256": { "$ref": "#/$defs/sha256" },
    "domain_policy_sha256": { "$ref": "#/$defs/sha256" },
    "test_catalog_sha256": { "$ref": "#/$defs/sha256" },
    "validation_harness_sha256": { "$ref": "#/$defs/sha256" },
    "trust_policy_sha256": { "$ref": "#/$defs/sha256" },
    "verification_plan": { "type": "string" },
    "verification_plan_sha256": { "$ref": "#/$defs/sha256" },
    "plan_material_sha256": { "$ref": "#/$defs/sha256" },
    "required_test_set_sha256": { "$ref": "#/$defs/sha256" },
    "evidence_bundle": { "type": "string" },
    "evidence_bundle_sha256": { "$ref": "#/$defs/sha256" },
    "evidence_bundle_digest": { "$ref": "#/$defs/sha256" },
    "capsule_set_sha256": { "$ref": "#/$defs/sha256" },
    "performance_evidence": { "type": "string", "minLength": 1 },
    "performance_evidence_sha256": { "$ref": "#/$defs/sha256" },
    "performance_status": { "const": "passed" },
    "manual_review_attestation": { "type": "string", "minLength": 1 },
    "manual_review_attestation_sha256": { "$ref": "#/$defs/sha256" },
    "manual_review_status": { "const": "passed" },
    "verifier_release_sha256": { "$ref": "#/$defs/sha256" },
    "producer_attestation": { "type": "object" },
    "sealed_at": { "type": "string", "format": "date-time" },
    "seal_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
  },
  "additionalProperties": false
}
