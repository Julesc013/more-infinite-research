{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://more-infinite-research.invalid/verification/capsule.schema.json",
  "title": "MIR immutable evidence capsule",
  "type": "object",
  "required": [
    "schema",
    "test_id",
    "status",
    "conclusion",
    "input_key",
    "fingerprint_sha256",
    "definition_sha256",
    "target",
    "layer",
    "producer",
    "assertions",
    "exit_code",
    "result",
    "artifacts",
    "stdout_sha256",
    "stderr_sha256",
    "result_digest",
    "attempt_path",
    "completed_at"
  ],
  "properties": {
    "schema": { "const": 4 },
    "test_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed"] },
    "conclusion": { "enum": ["passed", "failed"] },
    "disposition": { "const": "RUN" },
    "input_key": { "$ref": "#/$defs/sha256" },
    "fingerprint_sha256": { "$ref": "#/$defs/sha256" },
    "definition_sha256": { "$ref": "#/$defs/sha256" },
    "target": { "type": "string", "minLength": 1 },
    "layer": { "enum": ["F0", "F1", "F2", "F3", "F4"] },
    "command": { "type": "string" },
    "resolved_command": { "type": "string" },
    "inputs": { "type": "object" },
    "producer": { "type": "object" },
    "assertions": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "exit_code": { "type": "integer" },
    "result": { "type": "object" },
    "artifacts": { "type": "array", "items": { "type": "object" } },
    "stdout_sha256": { "$ref": "#/$defs/sha256" },
    "stderr_sha256": { "$ref": "#/$defs/sha256" },
    "log_digest": { "$ref": "#/$defs/sha256" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "message": { "type": "string" },
    "result_digest": { "$ref": "#/$defs/sha256" },
    "attempt_path": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
  },
  "additionalProperties": false
}
