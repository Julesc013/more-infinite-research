{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://more-infinite-research.invalid/verification/manual-release-attestation.schema.json",
  "title": "MIR package-focused manual release review",
  "type": "object",
  "required": [
    "schema",
    "kind",
    "candidate_sha256",
    "candidate_content_sha256",
    "source_commit",
    "checklist_version",
    "factorio_version",
    "factorio_binary_sha256",
    "reviewer",
    "reviewed_at",
    "items",
    "status",
    "attestation_sha256"
  ],
  "properties": {
    "schema": { "const": 2 },
    "kind": { "const": "mir-manual-release-review" },
    "candidate_sha256": { "$ref": "#/$defs/sha256" },
    "candidate_content_sha256": { "$ref": "#/$defs/sha256" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "checklist_version": { "const": "mir-manual-release-review-v1" },
    "factorio_version": { "type": "string", "minLength": 1 },
    "factorio_binary_sha256": { "$ref": "#/$defs/sha256" },
    "reviewer": { "type": "string", "minLength": 1 },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/item" }
    },
    "status": { "const": "passed" },
    "attestation_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "artifact": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "item": {
      "type": "object",
      "required": ["id", "status", "notes", "artifacts"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "const": "passed" },
        "notes": { "type": "string", "minLength": 1 },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifact" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
